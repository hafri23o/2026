{
  "name": "osho_digital_library",
  "version": "1.0.0",
  "description": "A comprehensive digital library of Osho's teachings and discourses.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "predeploy": "npm run build",
    "lint": "npx eslint src",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "npx prettier src --check",
    "prettier:fix": "npm run prettier -- --write",
    "format": "npm run prettier:fix && npm run lint:fix",
    "typecheck": "npx tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/css-tree": "^2.3.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "css-class-generator": "^2.0.0",
    "css-tree": "^3.1.0",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "gh-pages": "^6.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-solid": "^2.11.10"
  },
  "dependencies": {
    "@a11y/focus-trap": "^1.0.5",
    "@material/material-color-utilities": "^0.3.0",
    "@minht11/solid-virtual-container": "^0.2.1",
    "@otonashixav/solid-flip": "0.10.5",
    "@solid-primitives/deep": "^0.3.3",
    "@types/offscreencanvas": "^2019.7.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "buffer": "^6.0.3",
    "firebase": "^12.7.0",
    "fuzzysort": "^3.1.0",
    "idb-keyval": "^6.2.2",
    "js-yaml": "^4.1.1",
    "music-metadata": "^11.10.3",
    "nanoid": "^5.1.6",
    "solid-app-router": "^0.4.2",
    "solid-js": "^1.7.2",
    "solid-utils": "^0.8.1"
  }
}
