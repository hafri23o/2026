{
  "name": "osho_digital_library",
  "version": "1.0.0",
  "description": "A comprehensive digital library of Osho's teachings and discourses.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "predeploy": "npm run build",
    "lint": "npx eslint src",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "npx prettier src --check",
    "prettier:fix": "npm run prettier -- --write",
    "format": "npm run prettier:fix && npm run lint:fix",
    "typecheck": "npx tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/css-tree": "^1.0.8",
    "@types/js-yaml": "^4.0.11",
    "@types/node": "^18.17.1",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "@vanilla-extract/vite-plugin": "^3.2.0",
    "css-class-generator": "^2.0.0",
    "css-tree": "^2.2.0",
    "eslint": "^8.50.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "gh-pages": "^6.3.0",
    "prettier": "^2.8.0",
    "typescript": "^4.9.5",
    "vite": "^4.5.14", 
    "vite-plugin-html": "^3.2.0",
    "vite-plugin-solid": "^2.2.6"
  },
  "dependencies": {
    "@a11y/focus-trap": "^1.0.6",
    "@material/material-color-utilities": "^0.2.0",
    "@minht11/solid-virtual-container": "^0.3.0",
    "@otonashixav/solid-flip": "^0.11.0",
    "@solid-primitives/deep": "^0.2.8",
    "@types/offscreencanvas": "^2019.6.4",
    "@types/wicg-file-system-access": "^2020.9.5",
    "@vanilla-extract/css": "^1.8.0",
    "@vanilla-extract/dynamic": "^2.1.0",
    "@vanilla-extract/sprinkles": "^1.5.0",
    "firebase": "^9.24.0",
    "buffer": "^6.0.3",
    "fuzzysort": "^3.1.0",
    "idb-keyval": "^6.1.0",
    "js-yaml": "^4.1.0",
    "music-metadata": "^7.12.3",
    "nanoid": "^3.3.5",
    "solid-app-router": "^0.3.3",
    "solid-js": "^1.7.0",
    "solid-utils": "^0.8.2"
  }
}
